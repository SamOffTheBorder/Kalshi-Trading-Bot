# =============================================================================
# kalshi-bot configuration
#
# GENERATED FILE — do not edit by hand.
# Source of truth: src/kalshi_bot/config/settings.py
# Regenerate with:  uv run python scripts/generate_env_example.py
#
# Copy to `.env` and fill in values. Secrets are left blank; all credentials
# are optional — backtesting against public data needs none of them.
# =============================================================================

# Master switch. True = simulated fills only. Flipping to False is gated behind the live-trading
# confirmation flow; never edit casually.
PAPER_TRADING=true

# Kalshi API key ID from the Kalshi dashboard. Not needed for backtesting.
KALSHI_KEY_ID=

# Path to the RSA private key PEM used for RSA-PSS request signing. Keep under secrets/
# (gitignored). Kalshi cannot recover a lost key; rotate ~90 days.
KALSHI_PRIVATE_KEY_PATH=secrets/kalshi_private_key.pem

# True = Kalshi demo environment; False = production exchange.
KALSHI_USE_DEMO_ENV=true

# Webull OpenAPI App Key (apply via Webull OpenAPI Management portal).
WEBULL_APP_KEY=

# Webull OpenAPI App Secret.
WEBULL_APP_SECRET=

# True = api.sandbox.webull.com; False = production. Same code path either way.
WEBULL_USE_SANDBOX=true

# Total trading capital across all brokers, in USD.
BANKROLL_TOTAL_USD=200.0

# Fraction of total bankroll allocated to Kalshi (remainder goes to Webull). Each broker's
# allocation is drawdown-tracked independently.
BANKROLL_SPLIT_KALSHI_PCT=0.65

# Fractional Kelly multiplier. 0.25 = quarter-Kelly (conservative default; edge estimates are
# uncertain). Documented tunable band: 0.25-0.5.
KELLY_FRACTION=0.25

# Hard cap on any single position as a fraction of that broker's bankroll, applied AFTER Kelly
# sizing as a min() clamp. Kelly output can never exceed this.
MAX_POSITION_PCT=0.05

# Minimum fee-adjusted edge (expected value per contract dollar) required to enter. Fee is
# subtracted BEFORE this gate.
MIN_EDGE=0.05

# Maximum |BS - MC| probability disagreement. Larger divergence means the pricing model is
# strained -> HOLD regardless of apparent edge.
MAX_MODEL_DIVERGENCE=0.06

# Skip contracts whose estimated win probability is below this (longshot-bias guard; v1's losses
# clustered in cheap contracts).
MIN_ENTRY_PROBABILITY=0.3

# Skip contracts whose estimated win probability is above this (overpriced-favorite guard; thin
# payoff rarely survives fees).
MAX_ENTRY_PROBABILITY=0.8

# No new entries closer to expiry than this — near-expiry gamma noise makes model estimates
# unreliable.
MIN_MINUTES_TO_EXPIRY=10.0

# Drawdown from peak (per broker) at which NEW entries pause. Recalibrate against backtest output
# before live trading.
MAX_DRAWDOWN_PAUSE_PCT=0.25

# Drawdown from peak (per broker) triggering full halt + close-all via EmergencyControl. Must be >
# max_drawdown_pause_pct.
MAX_DRAWDOWN_HALT_PCT=0.4

# OpenRouter API key. Used ONLY for sparse high-stakes calls (pre-trade veto, periodic strategy
# review).
OPENROUTER_API_KEY=

# Hard monthly cap on OpenRouter spend. On exhaustion the bot falls back to :free-tier models /
# local Ollama; the veto gate stays fail-closed.
OPENROUTER_MONTHLY_BUDGET_USD=15.0

# Local Ollama endpoint for routine/frequent LLM tasks (regime classification).
OLLAMA_BASE_URL=http://localhost:11434

# Telegram bot token from @BotFather. Optional; enables Telegram alerts + commands.
TELEGRAM_BOT_TOKEN=

# Telegram chat ID authorized to command the bot. Commands from other chats are ignored.
TELEGRAM_CHAT_ID=

# Discord bot token. Optional; enables Discord alerts + commands.
DISCORD_BOT_TOKEN=

# SQLite database path (single schema of record). Portable to Postgres later.
DB_PATH=data/kalshi_bot.db

# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Shared secret for the LAN-exposed dashboard. Required before the web UI starts.
DASHBOARD_AUTH_SECRET=
